{
  "name": "wiper-query-system",
  "version": "1.0.0",
  "description": "雨刮器查询系统 - Cloudflare Pages + D1",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2024-01-01",
    "convert-data": "node scripts/convert-all-sheets.js",
    "db-create": "wrangler d1 create wiper_db",
    "db-init": "wrangler d1 execute wiper_db --file=schema.sql",
    "db-import": "wrangler d1 execute wiper_db --file=data-import-full.sql",
    "db-stats": "wrangler d1 execute wiper_db --command=\"SELECT COUNT(*) as total, COUNT(DISTINCT brand) as brands FROM wipers\""
  },
  "dependencies": {},
  "devDependencies": {
    "xlsx": "^0.18.5",
    "wrangler": "^3.0.0"
  }
}
